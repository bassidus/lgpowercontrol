#!/bin/bash
# LGPowerControl - Controls LG TV power state via bscpylgtv and Wake-on-LAN
# Usage: lgpowercontrol [ON|OFF|SCREEN_OFF|SCREEN_ON]

set -euo pipefail

# Replaced by install.sh
readonly BIN=(LGCOMMAND)
readonly HDMI="INPUT"
readonly PWR_ON_CMD=(WOL_CMD)

log() { logger -t "lgpowercontrol" -p "user.$1" "$2"; }

get_tv_state() {
    local out
    out=$("${BIN[@]}" get_power_state 2>/dev/null) || true
    echo "$out" | grep -oP "'state': '\K[^']+" || true
}

power_on() {
    log info "WOL: ${PWR_ON_CMD[*]}"
    if ! "${PWR_ON_CMD[@]}"; then
        log err "WOL failed"
        return 1
    fi
    if [[ -n "$HDMI" ]]; then
        sleep 1
        "${BIN[@]}" set_input "$HDMI"
    fi
}

[[ -z "${1:-}" ]] && { log err "No action provided"; exit 1; }

tv_state=$(get_tv_state)

case "$1" in
    ON)
        [[ "$tv_state" == "Active" ]] && { log info "Already ON"; exit 0; }
        power_on
        ;;
    OFF)
        [[ "$tv_state" == "Active Standby" ]] && { log info "Already OFF"; exit 0; }
        log info "power_off"
        "${BIN[@]}" power_off
        ;;
    SCREEN_OFF)
        log info "turn_screen_off"
        "${BIN[@]}" turn_screen_off
        ;;
    SCREEN_ON)
        if [[ "$tv_state" == "Active Standby" || -z "$tv_state" ]]; then
            log info "TV powered off, using WOL"
            power_on
        else
            log info "turn_screen_on"
            "${BIN[@]}" turn_screen_on
        fi
        ;;
    *)
        log err "Invalid action: $1"
        exit 1
        ;;
esac