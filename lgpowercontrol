#!/bin/bash
# LGPowerControl — TV power on/off via bscpylgtv + WoL
# Usage: lgpowercontrol ON|OFF

set -euo pipefail

readonly BIN="LGCOMMAND"
readonly HDMI="INPUT"
readonly WOL="WOL_CMD"
readonly ACTION="${1:-}"

log() { logger -t lgpowercontrol -p "user.$1" "$2"; }

if [[ -z "$ACTION" ]]; then
    log err "No action provided"
    exit 1
fi

current_state=$($BIN get_power_state 2>/dev/null | grep -oP '"state": "\K[^"]+' || true)

case "$ACTION" in
    ON)
        [[ "$current_state" == "Active" ]] && { log info "TV already on"; exit 0; }
        log info "Power ON: $WOL"
        if ! $WOL; then
            log err "WoL failed"
            exit 1
        fi
        if [[ -n "$HDMI" ]]; then
            sleep 1
            log info "Setting input: $HDMI"
            $BIN set_input "$HDMI"
        fi
        ;;
    OFF)
        [[ "$current_state" == "Active Standby" ]] && { log info "TV already off"; exit 0; }
        log info "Power OFF"
        $BIN power_off
        ;;
    *)
        log err "Invalid action: $ACTION"
        exit 1
        ;;
esac