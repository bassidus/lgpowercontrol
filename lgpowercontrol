#!/bin/bash
# LGPowerControl — TV power on/off via bscpylgtv + WoL
# Usage: lgpowercontrol ON|OFF

set -euo pipefail

INSTALL_PATH="$(dirname "$(realpath "$0")")"
CONFIG="$INSTALL_PATH/lgpowercontrol.conf"
[[ -f "$CONFIG" ]] || { echo "Error: config not found: $CONFIG" >&2; exit 1; }
# shellcheck source=/dev/null
source "$CONFIG"

ACTION="${1:?No action provided}"
BIN="$INSTALL_PATH/bscpylgtv/bin/bscpylgtvcommand -p $INSTALL_PATH/.aiopylgtv.sqlite $LGTV_IP"
BOOT_SHUTDOWN_MODE="${BOOT_SHUTDOWN_MODE:-power}"

log() { logger -t lgpowercontrol -p "user.$1" "$2"; }

case "$ACTION" in
    ON)
        if [[ "$BOOT_SHUTDOWN_MODE" == "screen" ]]; then
            log info "Screen ON"
            sleep 1
            $BIN turn_screen_on 2>&1 || { log info "Screen already on or not in standby"; exit 0; }
        else
            # WoL to an already-on TV is harmless; skip the slow WebSocket state check
            log info "Power ON: $WOL_CMD"
            if ! $WOL_CMD; then
                log err "WoL failed"
                exit 1
            fi
            if [[ -n "${HDMI_INPUT:-}" ]]; then
                sleep 1
                log info "Setting input: $HDMI_INPUT"
                $BIN set_input "$HDMI_INPUT"
            fi
        fi
        ;;
    OFF)
        if [[ "$BOOT_SHUTDOWN_MODE" == "screen" ]]; then
            log info "Screen OFF"
            $BIN turn_screen_off 2>&1 || { log info "Screen already off"; exit 0; }
        else
            current_state=$($BIN get_power_state 2>/dev/null | sed -n 's/.*"state": "\([^"]*\)".*/\1/p' || true)
            [[ "$current_state" == "Active Standby" ]] && { log info "TV already off"; exit 0; }
            log info "Power OFF"
            $BIN power_off
        fi
        ;;
    *)
        log err "Invalid action: $ACTION"
        exit 1
        ;;
esac