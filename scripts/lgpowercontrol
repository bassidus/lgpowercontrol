#!/bin/bash
set -euo pipefail

source /opt/lgpowercontrol/lgpowercontrol.conf

# Defaults guard against a conf preserved from a version predating the key.
mode="${2:-${BOOT_SHUTDOWN_MODE:-power}}"

log() {
    [[ "${LOGGING:-yes}" == "no" ]] && return 0
    logger -t lgpowercontrol -p user.info -- "$1"
}

send_wol() {
    if command -v wakeonlan &> /dev/null; then
        wakeonlan "$LGTV_MAC" > /dev/null
    else
        # Fedora and friends (net-tools). ether-wake defaults to eth0, so
        # look up the interface that actually routes to the TV.
        local iface
        iface=$(ip route get "$LGTV_IP" 2> /dev/null | sed -n 's/.* dev \([^ ]*\).*/\1/p')
        ether-wake -i "${iface:-eth0}" "$LGTV_MAC" > /dev/null
    fi
}

# bscpylgtvcommand wrapper; on Python tracebacks, logs only the final error line.
bscpylgtv() {
    local out rc=0

    out=$(/opt/lgpowercontrol/bscpylgtv/bin/bscpylgtvcommand \
        --connect_retry_attempts 3 -p /opt/lgpowercontrol/.aiopylgtv.sqlite \
        "$LGTV_IP" "$@" 2>&1) || rc=$?

    if [[ $rc -ne 0 ]]; then
        local msg=$out
        if [[ "$out" == *Traceback* ]]; then
            msg=$(grep -v '^[[:space:]]*$' <<< "$out" | tail -n 1)
            if [[ "$msg" == *"'errorText'"* ]]; then
                local exc code text
                exc=${msg%%:*}; exc=${exc##*.}
                code=$(sed -n "s/.*'errorCode': '\([^']*\)'.*/\1/p" <<< "$msg")
                text=$(sed -n "s/.*'errorText': [\"']\(.*\)[\"'][,}].*/\1/p" <<< "$msg")
                msg="${exc}: ${code} ${text}"
                [[ "$1" == turn_screen_on && "$code" == "-102" ]] && return 102
            fi
        fi
        log "bscpylgtv $*: ${msg//$'\n'/ }"
    fi

    return "$rc"
}

turn_tv_on() {
    # Resume fires ON from both the DRM watcher and the NM dispatcher;
    # only the lock holder proceeds.
    exec 9> /run/lgpowercontrol-on.lock
    if ! flock -n 9; then
        return 0
    fi

    log "Turning TV on (mode=${mode})"

    nm-online -q -t 15 || log "Network still down after 15s; trying anyway"

    local attempt rc=0
    for attempt in 1 2 3 4 5; do
        rc=0
        send_wol || log "WoL send failed"
        [[ "$mode" == "screen" ]] || break

        sleep 1 # Brief delay avoids a "No Signal" flash on the TV before the source is ready.
        bscpylgtv turn_screen_on || rc=$?
        if [[ $rc -eq 102 ]]; then
            log "turn_screen_on skipped - TV already waking via WoL"
            rc=0
        fi
        if [[ $rc -eq 0 ]]; then
            [[ $attempt -gt 1 ]] && log "TV on (attempt ${attempt}/5)"
            break
        fi

        log "turn_screen_on failed (attempt ${attempt}/5)"
        sleep 2
    done

    if [[ $rc -ne 0 ]]; then
        log "Giving up - TV unreachable"
        return "$rc"
    fi

    [[ -n "${HDMI_INPUT:-}" ]] || return 0

    # In power mode the TV may still be booting from the WoL, so retry.
    log "Setting input to ${HDMI_INPUT}"
    for attempt in 1 2 3 4 5; do
        bscpylgtv set_input "$HDMI_INPUT" && return 0
        log "set_input failed (attempt ${attempt}/5)"
        sleep 3
    done
    log "Giving up - could not set input"
    return 1
}

turn_tv_off() {
    log "Turning TV off (mode=${mode})"

    if [[ "$mode" == "screen" ]]; then
        bscpylgtv turn_screen_off
    else
        bscpylgtv power_off
    fi
}

case "${1:-}" in
    ON)  turn_tv_on  ;;
    OFF) turn_tv_off ;;
    *)   echo "Usage: lgpowercontrol ON|OFF [power|screen]" >&2; exit 1 ;;
esac