#!/bin/bash
set -euo pipefail

source /opt/lgpowercontrol/lgpowercontrol.conf

log() {
    [[ "${LOGGING:-yes}" == "no" ]] && return 0
    # LGPC_SOURCE is set by callers (monitor, dispatcher, systemd units) to
    # show who triggered the command; direct invocations log as "cli".
    logger -t lgpowercontrol -p user.info -- "${LGPC_SOURCE:-cli}: $1"
}

send_wol() {
    if [[ "${WOL_L3:-no}" == "yes" ]]; then
        # Routed magic packet for TVs on another subnet/VLAN, where broadcast
        # can't reach. Relies on the TV answering ARP in standby, which WebOS
        # networked standby does (issue #12).
        wol -i "$LGTV_IP" -p 9 "$LGTV_MAC" > /dev/null
    else
        # Broadcast (255.255.255.255): unicast to a sleeping TV needs an ARP
        # reply it doesn't always give - the packet is silently dropped.
        wol -p 9 "$LGTV_MAC" > /dev/null
    fi
}

# bscpylgtvcommand wrapper; on Python tracebacks, logs only the final error line.
# The raw output is left in $bscpylgtv_out for callers that need it.
bscpylgtv() {
    local rc=0

    bscpylgtv_out=$(/opt/lgpowercontrol/bscpylgtv/bin/bscpylgtvcommand \
        --connect_retry_attempts "${connect_retries:-3}" \
        -p /opt/lgpowercontrol/.aiopylgtv.sqlite \
        "$LGTV_IP" "$@" 2>&1) || rc=$?

    if [[ $rc -ne 0 ]]; then
        local msg=$bscpylgtv_out
        if [[ "$msg" == *Traceback* ]]; then
            msg=$(grep -v '^[[:space:]]*$' <<< "$msg" | tail -n 1)
            if [[ "$msg" == *"'errorText'"* ]]; then
                local exc code text
                exc=${msg%%:*}; exc=${exc##*.}
                code=$(sed -n "s/.*'errorCode': '\([^']*\)'.*/\1/p" <<< "$msg")
                text=$(sed -n "s/.*'errorText': [\"']\(.*\)[\"'][,}].*/\1/p" <<< "$msg")
                msg="${exc}: ${code} ${text}"
                # turn_screen_on errors with -102 when the screen is already
                # on; let the caller decide what that means - don't log it.
                [[ "$1" == turn_screen_on && "$code" == "-102" ]] && return 102
            fi
        fi
        log "bscpylgtv $*: ${msg//$'\n'/ }"
    fi

    return "$rc"
}

turn_tv_on() {
    # Resume fires ON from both the DPMS watcher and the NM dispatcher;
    # only the lock holder proceeds.
    exec 9> /run/lgpowercontrol-on.lock
    if ! flock -n 9; then
        return 0
    fi

    log "Turning TV on"
    rm -f /run/lgpowercontrol-tv-off

    # Fast connect cycles: the outer loop probes again anyway, so a single
    # connect attempt per cycle beats waiting out bscpylgtv's internal retries.
    local connect_retries=1

    nm-online -q -t 15 || log "Network still down after 15s; trying anyway"

    send_wol || log "WoL send failed"

    # Poll the TV until it is ready for turn_screen_on. A 'processing' field
    # means a WoL has bitten and the TV is mid-transition, e.g.
    # {'state': 'Active Standby', 'processing': 'Screen On'}; plain
    # 'Active Standby' means it is still asleep and the WoL was lost.
    local attempt state processing rc=1
    for attempt in {1..10}; do
        sleep 1 # Also avoids a "No Signal" flash on the TV before the source is ready.
        rc=1

        if ! bscpylgtv get_power_state; then
            log "get_power_state failed (attempt ${attempt}/10)"
            send_wol || log "WoL send failed"
            continue
        fi
        state=$(sed -n "s/.*'state': '\([^']*\)'.*/\1/p" <<< "$bscpylgtv_out")
        processing=$(sed -n "s/.*'processing': '\([^']*\)'.*/\1/p" <<< "$bscpylgtv_out")

        if [[ -n "$processing" ]]; then
            log "TV mid-transition: ${state} (${processing}) - waiting (attempt ${attempt}/10)"
            continue
        fi

        case "$state" in
            Active | "Screen Off" | "Screen Saver")
                rc=0
                bscpylgtv turn_screen_on || rc=$?
                # -102 = screen already on; the state above proves the TV is
                # awake, so that counts as success here.
                [[ $rc -eq 102 ]] && rc=0
                if [[ $rc -eq 0 ]]; then
                    [[ $attempt -gt 1 ]] && log "TV on (attempt ${attempt}/10)"
                    break
                fi
                log "turn_screen_on failed (attempt ${attempt}/10)"
                ;;
            *)
                log "TV in standby (${state:-?}) - resending WoL (attempt ${attempt}/10)"
                send_wol || log "WoL send failed"
                ;;
        esac
    done

    if [[ $rc -ne 0 ]]; then
        log "Giving up - TV unreachable"
        return "$rc"
    fi

    [[ -n "${HDMI_INPUT:-}" ]] || return 0

    # The TV may still be booting from the WoL, so retry.
    log "Setting input to ${HDMI_INPUT}"
    for attempt in {1..15}; do
        bscpylgtv set_input "$HDMI_INPUT" && return 0
        log "set_input failed (attempt ${attempt}/15)"
        sleep 1
    done
    log "Giving up - could not set input"
    return 1
}

turn_tv_off() {
    log "Turning TV off"
    bscpylgtv power_off || return $?
    # Lets the suspend hook skip a redundant power_off against a TV that is
    # already in standby (see 90-lgpowercontrol). Cleared by turn_tv_on.
    touch /run/lgpowercontrol-tv-off
}

turn_screen_off() {
    log "Turning screen off"
    bscpylgtv turn_screen_off
}

case "${1:-}" in
    ON)         turn_tv_on      ;;
    OFF)        turn_tv_off     ;;
    SCREEN_OFF) turn_screen_off ;;
    *)          echo "Usage: lgpowercontrol ON|OFF|SCREEN_OFF" >&2; exit 1 ;;
esac