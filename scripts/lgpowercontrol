#!/bin/bash
set -euo pipefail

source /opt/lgpowercontrol/lgpowercontrol.conf

mode="${2:-$BOOT_SHUTDOWN_MODE}"

log() {
    logger -t lgpowercontrol -p user.info -- "$1"
}

send_wol() {
    /usr/bin/wakeonlan -i "$LGTV_IP" "$LGTV_MAC"
}

# Wrapper around bscpylgtvcommand that logs clean error messages.
# On Python tracebacks, extracts just the final error line.
bscpylgtv() {
    local out rc=0

    out=$(/opt/lgpowercontrol/bscpylgtv/bin/bscpylgtvcommand \
        --connect_retry_attempts 1 -p /opt/lgpowercontrol/.aiopylgtv.sqlite \
        "$LGTV_IP" "$@" 2>&1) || rc=$?

    if [[ $rc -ne 0 ]]; then
        local msg=$out
        if [[ "$out" == *Traceback* ]]; then
            msg=$(grep -v '^[[:space:]]*$' <<< "$out" | tail -n 1)
        fi
        log "bscpylgtv $*: ${msg//$'\n'/ }"
    fi

    return "$rc"
}

turn_tv_on() {
    log "Turning TV on (mode=${mode})"

    if [[ "$mode" == "screen" ]]; then
        # Brief delay avoids a "No Signal" flash on the TV before the source is ready.
        sleep 1

        if ! bscpylgtv turn_screen_on; then
            log "TV likely powered off, falling back to WoL"
            send_wol
        fi
    else
        send_wol
    fi

    if [[ -n "${HDMI_INPUT:-}" ]]; then
        log "Setting input to ${HDMI_INPUT}"
        bscpylgtv set_input "$HDMI_INPUT"
    fi
}

turn_tv_off() {
    log "Turning TV off (mode=${mode})"

    if [[ "$mode" == "screen" ]]; then
        bscpylgtv turn_screen_off
    else
        bscpylgtv power_off
    fi
}

case "$1" in
    ON)  turn_tv_on  ;;
    OFF) turn_tv_off ;;
esac