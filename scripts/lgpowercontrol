#!/bin/bash
# LGPowerControl — TV power on/off via bscpylgtv + WoL
# Usage: lgpowercontrol ON|OFF [power|screen]
#   The mode argument defaults to BOOT_SHUTDOWN_MODE from the config.
#   Pass an explicit mode when calling from the monitor (MONITOR_MODE).

set -euo pipefail

# shellcheck source=/dev/null
source /opt/lgpowercontrol/lgpowercontrol.conf

readonly BIN=(/opt/lgpowercontrol/bscpylgtv/bin/bscpylgtvcommand -p /opt/lgpowercontrol/.aiopylgtv.sqlite "$LGTV_IP")

log() {
    local level="$1" msg="$2"
    [[ "$level" == "debug" && "${LOG_LEVEL:-info}" != "debug" ]] && return 0
    logger -t lgpowercontrol -p "user.$level" -- "$msg"
}

# Captures stdout+stderr and logs at debug level; nothing leaks to the journal under the wrong tag.
tv_cmd() {
    local out rc=0
    out=$("${BIN[@]}" "$@" 2>&1) || rc=$?
    if [[ $rc -ne 0 ]]; then
        # Log only the last line (the exception) — the full traceback collapses to one very long
        # line and gets truncated by the journal, hiding the actual error.
        log debug "bscpylgtv $*: failed (rc=$rc): ${out##*$'\n'}"
    else
        log debug "bscpylgtv $*: ${out//[$'\n\r']/ }"
    fi
    return $rc
}

# Returns the TV's current power state (e.g. "Active", "Screen Off", "Active Standby").
# bscpylgtvcommand prints a Python dict; we match single-quoted keys/values.
get_tv_state() {
    local raw rc=0
    raw=$("${BIN[@]}" --connect_retry_attempts 1 get_power_state 2>&1) || rc=$?
    if [[ $rc -ne 0 ]]; then
        log debug "get_power_state (rc=$rc): ${raw##*$'\n'}"
    else
        log debug "get_power_state (rc=$rc): ${raw//[$'\n\r']/ }"
    fi
    sed -n "s/.*'state': '\([^']*\)'.*/\1/p" <<< "$raw"
}

MODE="${2:-$BOOT_SHUTDOWN_MODE}"

case "$1" in  # ON or OFF
    ON)
        tv_state=$(get_tv_state)
        log info "Turning TV on (config_mode=$MODE, tv_state=${tv_state:-unknown})"

        if [[ "$tv_state" == "Active" ]]; then
            log info "TV already on — skipping"
            exit 0
        fi

        log debug "Sending WoL to $LGTV_IP ($LGTV_MAC)"
        "${WOL_CMD[@]}" || { log err "WoL failed"; exit 1; }
        log debug "WoL sent"

        if [[ "$MODE" == "screen" ]]; then
            sleep 1  # give the TV a moment to accept commands from the wake
            post_wol_state=$(get_tv_state)
            case "$post_wol_state" in
                Active) log info "TV already active after WoL — skipping turn_screen_on" ;;
                Suspend) log info "TV waking up (state: Suspend) — WoL will bring it on, skipping turn_screen_on" ;;
                *)
                    log info "Sending turn_screen_on (tv_state=${post_wol_state:-unknown})"
                    if ! tv_cmd turn_screen_on; then
                        actual_state=$(get_tv_state)
                        log warning "turn_screen_on command failed — actual TV state: ${actual_state:-unknown}"
                    fi ;;
            esac
        fi

        if [[ -n "${HDMI_INPUT:-}" ]]; then
            log info "Switching to input: $HDMI_INPUT"
            tv_cmd set_input "$HDMI_INPUT" || log warning "set_input $HDMI_INPUT failed"
        fi ;;

    OFF)
        tv_state=$(get_tv_state)
        log info "Turning TV off (config_mode=$MODE, tv_state=${tv_state:-unknown})"

        if [[ "$MODE" == "screen" ]]; then
            case "$tv_state" in
                "Active Standby"|"Screen Off") log info "TV already off — skipping"; exit 0 ;;
            esac

            log info "Sending turn_screen_off"
            for attempt in 1 2 3 4 5; do
                tv_cmd turn_screen_off && break
                if (( attempt == 5 )); then
                    actual_state=$(get_tv_state)
                    log err "turn_screen_off failed after 5 attempts — actual TV state: ${actual_state:-unknown}"
                    exit 1
                fi
                log warning "turn_screen_off command failed (attempt $attempt/5), retrying in 3s"
                sleep 3
            done
            log info "Screen off"
        else
            if [[ "$tv_state" == "Active Standby" ]]; then
                log info "TV already off — skipping"
                exit 0
            fi
            log info "Sending power_off"
            if ! tv_cmd power_off; then
                actual_state=$(get_tv_state)
                log warning "power_off command failed — actual TV state: ${actual_state:-unknown}"
            fi
            log info "Power off sent"
        fi ;;

    *)
        log err "Usage: $0 ON|OFF [power|screen]"; exit 2 ;;
esac
