#!/bin/bash
source /opt/lgpowercontrol/lgpowercontrol.conf

BIN=(/opt/lgpowercontrol/bscpylgtv/bin/bscpylgtvcommand -p /opt/lgpowercontrol/.aiopylgtv.sqlite "$LGTV_IP")
MODE="${2:-$BOOT_SHUTDOWN_MODE}"

log() { logger -t lgpowercontrol -p "user.info" -- "$1"; }

tv_cmd() {
    local out rc=0
    out=$("${BIN[@]}" "$@" 2>&1) || rc=$?
    log "bscpylgtv $*: ${out//[$'\n\r']/ }"
    return $rc
}

case "$1" in
    ON)
        log "Turning TV on (mode=$MODE)"
        "${WOL_CMD[@]}" && log "WoL sent"
        if [[ "$MODE" == "screen" ]]; then
            sleep 1
            tv_cmd turn_screen_on
        fi
        [[ -n "${HDMI_INPUT:-}" ]] && log "Setting input to $HDMI_INPUT" && tv_cmd set_input "$HDMI_INPUT"
        ;;
    OFF)
        log "Turning TV off (mode=$MODE)"
        if [[ "$MODE" == "screen" ]]; then
            tv_cmd turn_screen_off
        else
            tv_cmd power_off
        fi
        ;;
esac