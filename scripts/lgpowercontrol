#!/bin/bash

set -euo pipefail

# Load configuration: BIN, WOL_CMD, HDMI_INPUT, BOOT_SHUTDOWN_MODE.
source /opt/lgpowercontrol/lgpowercontrol.conf

# Use the second argument if provided; otherwise fall back to the configured default.
mode="${2:-$BOOT_SHUTDOWN_MODE}"

log() {
    logger -t lgpowercontrol -p user.info -- "$1"
}

tv_cmd() {
    local out rc=0
    out=$("${BIN[@]}" "$@" 2>&1) || rc=$?
    if [[ $rc -ne 0 ]]; then
        local msg="$out"
        if [[ "$out" == *"Traceback"* ]]; then
            msg=$(grep -v '^\s*$' <<< "$out" | tail -1)
        fi
        log "bscpylgtv $*: ${msg//$'\n'/ }"
    fi
    return "$rc"
}

turn_tv_on() {
    log "Turning TV on (mode=${mode})"
    if [[ "$mode" == "screen" ]]; then
        # Give the system a moment before issuing the screen-on command.
        sleep 1
            
        # If screen-on fails, fall back to WoL.
        if ! tv_cmd turn_screen_on; then
            log "turn_screen_on failed, falling back to WoL"
            "${WOL_CMD[@]}" && log "WoL packet sent"
        fi
    else
        "${WOL_CMD[@]}" && log "WoL packet sent"
    fi
    if [[ -n "${HDMI_INPUT:-}" ]]; then
        log "Setting input to ${HDMI_INPUT}"
        tv_cmd set_input "$HDMI_INPUT"
    fi
}

turn_tv_off() {
    log "Turning TV off (mode=${mode})"
    if [[ "$mode" == "screen" ]]; then
        tv_cmd turn_screen_off
    else
        tv_cmd power_off
    fi
}

case "$1" in
    ON)  turn_tv_on  ;;
    OFF) turn_tv_off ;;
esac