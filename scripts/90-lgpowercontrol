#!/bin/bash
# NetworkManager dispatcher script. Installed in dispatcher.d/ with a symlink
# from pre-down.d/, so it receives both the blocking pre-down event and the
# regular up event.
#
# pre-down: when the system is going to sleep, this blocking window is the
# last moment the network is still up, so the TV must be turned off here.
# NM's own logind delay inhibitor keeps the kernel from suspending until
# this script has finished.
#
# up: fires when the connection is back after resume - exactly when the
# network can carry a WoL packet. The sleep flag set at pre-down tells
# resume apart from boot and cable replug, which must not touch the TV.

source /opt/lgpowercontrol/lgpowercontrol.conf

case "$2" in
pre-down)
    busctl get-property org.freedesktop.login1 /org/freedesktop/login1 \
        org.freedesktop.login1.Manager PreparingForSleep | grep -q true || exit 0

    # Fires once per NIC; only act on the first. Cleared by the up event.
    [[ -e /run/lgpowercontrol-sleep ]] && exit 0
    touch /run/lgpowercontrol-sleep

    /opt/lgpowercontrol/lgpowercontrol OFF "$MONITOR_MODE"
    ;;
up)
    [[ -e /run/lgpowercontrol-sleep ]] || exit 0
    rm -f /run/lgpowercontrol-sleep

    # Detached: NM runs dispatcher scripts sequentially, and the ON path can
    # retry for up to a minute, which must not hold up the event queue.
    systemd-run --quiet --collect /opt/lgpowercontrol/lgpowercontrol ON "$MONITOR_MODE"
    ;;
esac
