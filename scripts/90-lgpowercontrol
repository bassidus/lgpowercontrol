#!/bin/bash
# NetworkManager dispatcher script. Lives in dispatcher.d/ with a symlink in
# pre-down.d/ to receive both events.
#
# pre-down: blocking window at suspend where the network is still up; NM's
# logind inhibitor delays the kernel until this script finishes.
# up: network is back after resume. The flag set at pre-down separates
# resume from boot and cable replug.

source /opt/lgpowercontrol/lgpowercontrol.conf

log() {
    [[ "${LOGGING:-yes}" == "no" ]] && return 0
    logger -t lgpowercontrol -p user.info -- "$1"
}

case "$2" in
pre-down)
    busctl get-property org.freedesktop.login1 /org/freedesktop/login1 \
        org.freedesktop.login1.Manager PreparingForSleep | grep -q true || exit 0

    # Fires once per NIC; only act on the first. Cleared by the up event.
    [[ -e /run/lgpowercontrol-sleep ]] && exit 0
    touch /run/lgpowercontrol-sleep

    log "System going to sleep"
    # The monitor's 10-min escalation may already have powered the TV off;
    # a second power_off would just hang against a standby TV and delay
    # suspend until the connect timeout.
    if [[ -e /run/lgpowercontrol-tv-off ]]; then
        log "TV already powered off - skipping"
        exit 0
    fi
    # Full power off: lands the TV in Always Ready where available.
    /opt/lgpowercontrol/lgpowercontrol OFF
    ;;
up)
    [[ -e /run/lgpowercontrol-sleep ]] || exit 0
    rm -f /run/lgpowercontrol-sleep

    log "System woke up"

    # Detached: dispatcher scripts run sequentially and ON can retry for a minute.
    systemd-run --quiet --collect /opt/lgpowercontrol/lgpowercontrol ON
    ;;
esac
